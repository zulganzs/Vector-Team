{
  "name": "blazewatch-backend",
  "version": "1.0.0",
  "description": "BlazeWatch — IoT Fire Detection System Backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "author": "Vector Team",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "5.1.1",
    "better-sqlite3": "11.9.1",
    "bullmq": "5.34.5",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "ioredis": "5.4.2",
    "jsonwebtoken": "9.0.2",
    "knex": "3.1.0",
    "mqtt": "5.10.4",
    "node-cron": "3.0.3",
    "socket.io": "4.8.1",
    "twilio": "5.4.5",
    "uuid": "11.1.0",
    "winston": "3.17.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "9.20.0",
    "@types/bcrypt": "5.0.2",
    "@types/better-sqlite3": "7.6.12",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.13.14",
    "@types/node-cron": "3.0.11",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.24.0",
    "@typescript-eslint/parser": "8.24.0",
    "eslint": "9.20.0",
    "jest": "29.7.0",
    "nodemon": "3.1.9",
    "prettier": "3.5.1",
    "supertest": "7.0.0",
    "ts-jest": "29.2.6",
    "ts-node": "10.9.2",
    "typescript": "5.7.3"
  }
}
