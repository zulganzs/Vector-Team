# ============================================================
# BlazeWatch Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── Application ────────────────────────────────────────────
APP_NAME=BlazeWatch
APP_ENV=production
# Public URL of the API (used in SMS templates, etc.)
APP_URL=https://api.blazewatch.id

# ─── Database ────────────────────────────────────────────────
DB_CONNECTION=sqlite
# Path to the SQLite database file (absolute or relative to project root)
DB_PATH=./data/blazewatch.sqlite

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT Authentication ───────────────────────────────────────
# MUST be at least 64 characters long
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-long-please-change-in-production
# Access token TTL in minutes (default: 15)
JWT_TTL=15
# Refresh token TTL in minutes (default: 10080 = 7 days)
JWT_REFRESH_TTL=10080

# ─── Twilio SMS ───────────────────────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567
# Firefighter / fire station phone number to receive SMS alerts
FIREFIGHTER_PHONE_NUMBER=+62811234567

# ─── Socket.IO ───────────────────────────────────────────────
# CORS origin for the frontend (e.g. Vite dev server)
SOCKETIO_CORS_ORIGIN=http://localhost:5173
SOCKETIO_PORT=8080

# ─── Fire Detection Thresholds ────────────────────────────────
# Smoke value threshold for WARNING level (default: 300)
SMOKE_THRESHOLD_WARNING=300
# Smoke value threshold for DANGER level (default: 600)
SMOKE_THRESHOLD_DANGER=600
# Seconds without data before a sensor is considered offline (default: 60)
SENSOR_OFFLINE_THRESHOLD_SECONDS=60

# ─── IoT / MQTT ───────────────────────────────────────────────
# API key for IoT sensors to authenticate HTTP data ingestion
SENSOR_API_KEY=your-sensor-api-key-here
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=blazewatch/sensors

# ─── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
