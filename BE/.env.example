# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=BlazeWatch
APP_URL=http://localhost:3000

# ─── Database (SQLite) ────────────────────────────────────────────────────────
# Path to SQLite file, relative to project root
DB_PATH=./data/blazewatch.sqlite

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Minimum 64 characters recommended for production
JWT_SECRET=change-me-to-a-very-long-random-secret-string-at-least-64-chars
JWT_TTL=15            # Access token TTL in minutes
JWT_REFRESH_TTL=10080 # Refresh token TTL in minutes (7 days)

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
# Get from https://console.twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
FIREFIGHTER_PHONE_NUMBER=+62811xxxxxxxx

# ─── Socket.IO ────────────────────────────────────────────────────────────────
SOCKETIO_CORS_ORIGIN=http://localhost:5173
SOCKETIO_PORT=8080

# ─── Fire Detection Thresholds ────────────────────────────────────────────────
# ADC values (0–4095 range) for smoke classification
SMOKE_THRESHOLD_WARNING=300
SMOKE_THRESHOLD_DANGER=600
SENSOR_OFFLINE_THRESHOLD_SECONDS=60

# ─── IoT / MQTT ───────────────────────────────────────────────────────────────
# SHA-256 of the actual API key stored here for comparison
SENSOR_API_KEY=change-me-to-a-random-secret-sensor-api-key
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=blazewatch/sensors
